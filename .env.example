# ─── WhatsApp Cloud API ───────────────────────────────────────────────
WA_ACCESS_TOKEN=your_meta_access_token_here
WA_PHONE_NUMBER_ID=your_phone_number_id_here
WA_VERIFY_TOKEN=clinic_verify_2026_xyz
WA_API_VERSION=v22.0
# App secret — REQUIRED in production (verifies inbound webhook signatures)
WA_APP_SECRET=your_meta_app_secret_here

# ─── Database (Postgres) ──────────────────────────────────────────────
# Railway/Heroku set this automatically. For docker-compose use the value below.
DATABASE_URL=postgresql://clinic:clinic@localhost:5432/clinic

# ─── LLM providers (fallback order) ───────────────────────────────────
# Order = fallback order. Each needs its key set to be usable.
# Claude is paid but reliable (no free-tier daily caps); keep it first.
AI_PROVIDERS=claude,gemini,groq,deepseek
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-haiku-4-5-20251001
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# ─── Operations ───────────────────────────────────────────────────────
# Staff WhatsApp number for escalations (E.164, no plus, e.g. 9665XXXXXXXX)
ADMIN_WA_NUMBER=9665XXXXXXXX
# Admin dashboard
ADMIN_PASSWORD=change-me
SECRET_KEY=generate-a-long-random-string
# Clinic timezone (defaults to Asia/Riyadh)
CLINIC_TIMEZONE=Asia/Riyadh

PORT=8000
