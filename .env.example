# ─── WhatsApp Cloud API ───────────────────────────────────────────────
WA_ACCESS_TOKEN=your_meta_access_token_here
WA_PHONE_NUMBER_ID=your_phone_number_id_here
WA_VERIFY_TOKEN=clinic_verify_2026_xyz
WA_API_VERSION=v22.0
# App secret — REQUIRED in production (verifies inbound webhook signatures)
WA_APP_SECRET=your_meta_app_secret_here

# ─── Database (Postgres) ──────────────────────────────────────────────
# Railway/Heroku set this automatically. For docker-compose use the value below.
DATABASE_URL=postgresql://clinic:clinic@localhost:5432/clinic

# ─── LLM providers (fallback order) ───────────────────────────────────
# Order = fallback order. Each needs its key set to be usable.
# Claude is paid (best tool-use quality); the others have free tiers.
AI_PROVIDERS=claude,mistral,openrouter,gemini,groq,deepseek
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# Mistral AI (OpenAI-compatible, tool calling).
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
# OpenRouter: one key, many models. Set OPENROUTER_MODEL to any tool-calling model.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o
# Self-hosted "own" model (Ollama / vLLM / RunPod serverless) — always-on fallback,
# no credit to run out of. Set the OpenAI base URL to enable; key optional.
SELFHOSTED_BASE_URL=
SELFHOSTED_API_KEY=
SELFHOSTED_MODEL=qwen2.5:14b-instruct

# Voice notes: transcription fallback chain (tried in order, missing keys skipped).
# Note: OpenRouter requires a >=$0.50 OpenRouter balance for ANY audio request.
TRANSCRIBE_PROVIDERS=gemini,groq,openrouter,openai
TRANSCRIBE_MODEL=gemini-2.5-flash
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
OPENAI_WHISPER_MODEL=whisper-1
# OpenRouter transcribes via an audio-capable chat model (reuses OPENROUTER_API_KEY).
OPENROUTER_TRANSCRIBE_MODEL=google/gemini-2.0-flash-001
# Needed only if you want OpenAI Whisper as a transcription fallback.
OPENAI_API_KEY=

# ─── LLM resilience ───────────────────────────────────────────────────
# Per-call timeout (s) for any single provider request.
LLM_TIMEOUT_S=30
# Circuit breaker: skip a provider after this many consecutive failures, for
# LLM_BREAKER_COOLDOWN_S seconds, so a dead provider isn't retried every message.
LLM_BREAKER_THRESHOLD=3
LLM_BREAKER_COOLDOWN_S=60

# ─── Operations ───────────────────────────────────────────────────────
# Staff WhatsApp number for escalations (E.164, no plus, e.g. 9665XXXXXXXX)
ADMIN_WA_NUMBER=9665XXXXXXXX
# Admin dashboard
ADMIN_PASSWORD=change-me
SECRET_KEY=generate-a-long-random-string
# Clinic timezone (defaults to Asia/Riyadh)
CLINIC_TIMEZONE=Asia/Riyadh

PORT=8000

# ─── No-show recovery & risk prediction ───────────────────────────────
# Master switch for the whole feature (detection sweep + recovery outreach).
NO_SHOW_ENABLED=true
# Auto-send the recovery WhatsApp the moment a no-show is detected. When false,
# staff send it manually from the No-shows dashboard.
NO_SHOW_AUTO_SEND=true
# Minutes after an appointment's end time before a still-confirmed booking is a no-show.
NO_SHOW_GRACE_MINUTES=30
# How often the background detection/outreach sweep runs (minutes).
NO_SHOW_SWEEP_INTERVAL_MIN=15
# Silence (hours) before the day-later follow-up, then before the lead goes inactive.
NO_SHOW_FOLLOWUP_HOURS=24
NO_SHOW_INACTIVE_HOURS=24
# Premium predictor: score upcoming appointments and give high-risk patients an extra
# reminder this many hours before the appointment.
NO_SHOW_PREDICTOR=true
NO_SHOW_RISK_REMINDER_LEAD_HOURS=24
# Use pre-approved WhatsApp message templates for the proactive no-show messages.
# Required to reach patients OUTSIDE WhatsApp's 24h window. Turn on once the templates
# are approved in WhatsApp Manager. Body variables: no_show/followup -> {{1}} = appointment
# summary; reminder -> {{1}} = appointment summary, {{2}} = date & time.
# (A clinic can override names/language per-tenant via clinic_data.no_show_templates.)
NO_SHOW_USE_TEMPLATES=false
NO_SHOW_TEMPLATE_LANG=en
WA_TEMPLATE_NO_SHOW=
WA_TEMPLATE_FOLLOWUP=
WA_TEMPLATE_REMINDER=
